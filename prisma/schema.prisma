// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model ActiveSubscription {
  id              String   @id @default(uuid())
  shopDomain      String   @unique
  plan            Plan
  subscriptionId  String
  popupShown      Boolean  @default(false)
  currentPeriodEnd       DateTime
}

enum Plan {
  FREE
  BASIC
  ADVANCED
}

enum SubscriptionStatus {
  CREATED
  ACTIVATED
  CANCELLED
  UPGRADED
}

model FreePlanLimits {
  id                 String   @id @default(uuid())
  shopDomain         String   @unique

  // TAG LIMITS
  tagGlobal          Int      @default(2)

  // METAFIELD LIMITS
  metaGlobal         Int      @default(2)

  // CSV LIMITS
  metaRemoveCsvLimit           Int      @default(200)
  metaUpdateCsvLimit           Int      @default(200)
  tagAddCsvLimit               Int      @default(200)
  tagRemoveCsvLimit            Int      @default(200)
  
  firstUsedAt        DateTime @default(now())
}

model BasicPlanLimits {
  id                 String   @id @default(uuid())
  shopDomain         String   @unique

  // TAG LIMITS
  tagGlobal          Int      @default(20)

  // METAFIELD LIMITS
  metaGlobal         Int      @default(20)

  // CSV LIMITS
  metaRemoveCsvLimit           Int      @default(3000)
  metaUpdateCsvLimit           Int      @default(3000)
  tagAddCsvLimit               Int      @default(3000)
  tagRemoveCsvLimit            Int      @default(3000)

  firstUsedAt        DateTime @default(now())
}
